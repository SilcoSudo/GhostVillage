--- !u!114 &1302912657
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1302912655}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f5507388d64718547b7c063dc364dd6f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Game.Scripts.UI.Lobby.TutorialModalUI
  _imgTutorialPic: {fileID: 500067653}
  _txtTutorialTitle: {fileID: 1257256919}
  _txtTutorialDesc: {fileID: 1819607084}
  _btnNext: {fileID: 681200803}
  _btnPrev: {fileID: 1692948842}
  _btnClose: {fileID: 672919418}
  _slides:
  - Title: Game Objective
    Description: '```text Survive and escape! Explore the dark environment to find
      hidden <b><color=#FFD700>Key Items</color></b>. Bring these items to the <b><color=#FFD700>Main
      Altar</color></b> to complete the ritual and unlock your path to freedom. Work
      together with your team, but remember: <b><color=#FF4500>time is running out</color></b>.'
    Image: {fileID: 0}
  - Title: Basic Controls
    Description: "```text\nMaster your movement to survive:\n\u2022 <b><color=#FFD700>WASD
      / Mouse</color></b>: Move and Look around.\n\u2022 <b><color=#FFD700>Sprint
      Key</color></b>: Run fast, but watch your <b><color=#00FF00>Stamina</color></b>!
      If it drains, you'll be exhausted.\n\u2022 <b><color=#FFD700>[F]</color></b>:
      <b>Interact</b> (Open doors, read notes, pick up items).\n\u2022 <b><color=#FFD700>[ESC]</color></b>:
      Open settings menu."
    Image: {fileID: 0}
  - Title: Inventory & HUD
    Description: "```text\nYou have a limited inventory with <b>3 slots</b>.\n\u2022
      <b><color=#FFD700>[1], [2], [3]</color></b>: <b>Equip</b> an item from your
      inventory.\n\u2022 <b><color=#FFD700>[E]</color></b>: <b>Use</b> the equipped
      item (e.g., consume health or use tool).\n\u2022 <b><color=#FFD700>Drop Key</color></b>:
      <b>Drop</b> the current item for teammates.\nAlways keep an eye on your <b><color=#FF4500>Health</color></b>
      and <b><color=#00FF00>Stamina</color></b> bars on the screen!"
    Image: {fileID: 0}
  - Title: Threats & Puzzles
    Description: "```text You are not alone. Terrifying <b><color=#FF4500>Monsters</color></b>
      roam the area. You cannot fight them directly\u2014<b>hide, run, and stay quiet!</b>  
      Along the way, you will encounter deadly <b><color=#FFD700>Puzzles</color></b>.
      Solve them as a team to reveal the hidden <b><color=#FFD700>Key Items</color></b>
      needed for the ritual."
    Image: {fileID: 0}
  - Title: Teamwork & Lobby
    Description: "```text\nCommunication is your best weapon. Use <b><color=#00FFFF>Voice
      Chat</color></b> to warn your team and strategize.\n\u2022 <b>Lobby Host</b>:
      The room creator can manage map settings and <b><color=#FF4500>Kick</color></b>
      disruptive players.\n\u2022 <b>Ready Up</b>: Don't forget to set your status
      to <b><color=#00FF00>READY</color></b> so the Host can start the match. Good
      luck!"
    Image: {fileID: 0}
